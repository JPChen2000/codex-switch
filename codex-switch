#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$HOME/.codex"

# 列出可用的 key
_list_keys() {
  echo "可用的 key:"
  (ls "$SCRIPT_DIR"/config.toml.*.bak 2>/dev/null || true) | while read -r f; do
    basename "$f" | sed 's/^config\.toml\.//;s/\.bak$//'
  done | sort -u | while read -r k; do echo "  - $k"; done
}

case "${1:-}" in
  --list|-l)
    _list_keys
    exit 0
    ;;
  --show)
    CONFIG_FILE="$SCRIPT_DIR/config.toml"
    AUTH_FILE="$SCRIPT_DIR/auth.json"

    if [[ ! -f "$CONFIG_FILE" ]]; then
      echo "错误: 找不到 $CONFIG_FILE"
      exit 1
    fi

    if [[ ! -f "$AUTH_FILE" ]]; then
      echo "错误: 找不到 $AUTH_FILE"
      exit 1
    fi

    BASE_URL=$(grep '^base_url' "$CONFIG_FILE" | sed 's/.*base_url = "\(.*\)"/\1/')
    API_KEY=$(python3 -c "import json; d=json.load(open('$AUTH_FILE')); print(d.get('OPENAI_API_KEY','(未设置)'))")

    echo "base_url : $BASE_URL"
    echo "api_key  : $API_KEY"
    exit 0
    ;;
  --help|-h)
    echo "用法:"
    echo "  $0 <key>                        切换到指定配置"
  echo "  $0 --save <key>                 保存当前配置为指定 key"
  echo "  $0 --show                       显示当前 base_url 和 api_key"
    echo "  $0 --base_url <url> --api_key <key> [--save <key>]"
    echo "                                    设置 base_url 和 api_key"
    echo "  $0 --base_url <url> --api_key <key> --save <key>  更新并保存为新配置"
    echo "  $0 --rm <key>                                     删除指定配置"
    echo "  $0 --list, -l                             列出可用的 key"
    echo "  $0                                          列出可用的 key"
    exit 0
    ;;
esac

if [[ $# -lt 1 ]]; then
  echo "用法:"
  echo "  $0 <key>                        切换到指定配置"
  echo "  $0 --save <key>                 保存当前配置为指定 key"
  echo "  $0 --show                       显示当前 base_url 和 api_key"
  echo "  $0 --base_url <url> --api_key <key> [--save <key>]"
  echo "                                    设置 base_url 和 api_key"
  echo "  $0 --base_url <url> --api_key <key> --save <key>  更新并保存为新配置"
  echo "  $0 --rm <key>                                     删除指定配置"
  echo "  $0 --list, -l                             列出可用的 key"
  echo "  $0                                          列出可用的 key"
  echo
  _list_keys
  exit 1
fi

SAVE="false"
RM="false"
KEY=""
BASE_URL=""
API_KEY=""

# 解析参数
while [[ $# -gt 0 ]]; do
  case "$1" in
    --save)
      SAVE="true"
      shift
      if [[ $# -lt 1 ]]; then echo "错误: --save 需要指定 key"; exit 1; fi
      KEY="$1"
      shift
      ;;
    --rm)
      RM="true"
      shift
      if [[ $# -lt 1 ]]; then echo "错误: --rm 需要指定 key"; exit 1; fi
      KEY="$1"
      shift
      ;;
    --base_url)
      BASE_URL="$2"
      shift 2 || { echo "错误: --base_url 需要指定值"; exit 1; }
      ;;
    --api_key)
      API_KEY="$2"
      shift 2 || { echo "错误: --api_key 需要指定值"; exit 1; }
      ;;
    *)
      if [[ -z "$KEY" ]]; then
        KEY="$1"
      fi
      shift
      ;;
  esac
done

# 如果同时提供了 --base_url/--api_key，先更新配置
if [[ -n "$BASE_URL" ]] || [[ -n "$API_KEY" ]]; then
  if [[ -z "$BASE_URL" ]] || [[ -z "$API_KEY" ]]; then
    echo "错误: --base_url 和 --api_key 必须同时提供"
    exit 1
  fi

  # 更新 config.toml 中的 base_url
  sed -i "s|base_url = \".*\"|base_url = \"${BASE_URL}\"|" "$SCRIPT_DIR/config.toml"
  echo "已更新 config.toml: base_url = \"${BASE_URL}\""

  # 更新 auth.json 中的 OPENAI_API_KEY
  python3 -c "
import json
with open('$SCRIPT_DIR/auth.json', 'r') as f:
    data = json.load(f)
data['OPENAI_API_KEY'] = '$API_KEY'
with open('$SCRIPT_DIR/auth.json', 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
"
  echo "已更新 auth.json: OPENAI_API_KEY"

  # 如果同时提供了 --save，将更新后的配置保存为新 key
  if [[ "$SAVE" == "true" ]] && [[ -n "$KEY" ]]; then
    CONFIG_DST="$SCRIPT_DIR/config.toml.${KEY}.bak"
    AUTH_DST="$SCRIPT_DIR/auth.json.${KEY}.bak"

    if [[ -f "$CONFIG_DST" ]] || [[ -f "$AUTH_DST" ]]; then
      echo "警告: config.toml.${KEY}.bak 或 auth.json.${KEY}.bak 已存在，将被覆盖"
      read -r -p "确认覆盖? [y/N] " confirm
      if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "取消"
        exit 0
      fi
    fi

    cp "$SCRIPT_DIR/config.toml" "$CONFIG_DST"
    echo "已保存 config.toml --> config.toml.${KEY}.bak"

    cp "$SCRIPT_DIR/auth.json" "$AUTH_DST"
    echo "已保存 auth.json   --> auth.json.${KEY}.bak"
  fi

elif [[ "$SAVE" == "true" ]]; then
  if [[ -z "$KEY" ]]; then
    echo "错误: --save 需要指定 key"
    echo "用法: $0 --save <key>"
    exit 1
  fi

  CONFIG_DST="$SCRIPT_DIR/config.toml.${KEY}.bak"
  AUTH_DST="$SCRIPT_DIR/auth.json.${KEY}.bak"

  if [[ -f "$CONFIG_DST" ]] || [[ -f "$AUTH_DST" ]]; then
    echo "警告: config.toml.${KEY}.bak 或 auth.json.${KEY}.bak 已存在，将被覆盖"
    read -r -p "确认覆盖? [y/N] " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
      echo "取消"
      exit 0
    fi
  fi

  cp "$SCRIPT_DIR/config.toml" "$CONFIG_DST"
  echo "已保存 config.toml --> config.toml.${KEY}.bak"

  cp "$SCRIPT_DIR/auth.json" "$AUTH_DST"
  echo "已保存 auth.json   --> auth.json.${KEY}.bak"

elif [[ "$RM" == "true" ]]; then
  if [[ -z "$KEY" ]]; then
    echo "错误: --rm 需要指定 key"
    echo "用法: $0 --rm <key>"
    exit 1
  fi

  CONFIG_SRC="$SCRIPT_DIR/config.toml.${KEY}.bak"
  AUTH_SRC="$SCRIPT_DIR/auth.json.${KEY}.bak"

  if [[ ! -f "$CONFIG_SRC" ]] && [[ ! -f "$AUTH_SRC" ]]; then
    echo "错误: 找不到 $CONFIG_SRC 和 $AUTH_SRC"
    exit 1
  fi

  rm -f "$CONFIG_SRC"
  echo "已删除 config.toml.${KEY}.bak"

  rm -f "$AUTH_SRC"
  echo "已删除 auth.json.${KEY}.bak"

else
  if [[ -z "$KEY" ]]; then
    echo "可用 key:"
    _list_keys
    exit 0
  fi

  CONFIG_SRC="$SCRIPT_DIR/config.toml.${KEY}.bak"
  AUTH_SRC="$SCRIPT_DIR/auth.json.${KEY}.bak"

  if [[ ! -f "$CONFIG_SRC" ]]; then
    echo "错误: 找不到 $CONFIG_SRC"
    exit 1
  fi

  if [[ ! -f "$AUTH_SRC" ]]; then
    echo "错误: 找不到 $AUTH_SRC"
    exit 1
  fi

  cp "$CONFIG_SRC" "$SCRIPT_DIR/config.toml"
  echo "已切换 config.toml <-- config.toml.${KEY}.bak"

  cp "$AUTH_SRC" "$SCRIPT_DIR/auth.json"
  echo "已切换 auth.json   <-- auth.json.${KEY}.bak"
fi
